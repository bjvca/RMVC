\begin_layout Subsection
Estimation
\end_layout

\begin_layout Standard
\begin_inset CommandInset label
LatexCommand label
name "subsec:estimation"

\end_inset

[Placeholder describing the estimation strategy.
 Intent-to-treat (ITT) effects are estimated using OLS with CR2 cluster-robust
 standard errors (clubSandwich).
 Local Average Treatment Effects (LATE) are estimated via two-stage least
 squares, instrumenting actual machine use with random assignment.
 The orthogonalized factorial specification follows Muralidharan et al.,
 using demeaned treatment indicators to isolate individual treatment effects
 that are invariant to the other treatment arm.
 Anderson indices are constructed as summary measures across outcome families.
 Multiple testing is addressed using Anderson-Sharp q-values.]
\end_layout

