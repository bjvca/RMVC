\begin_layout Title
Technology, Incentives, and the Emergence of Markets for Quality: Evidence
 from Ugandan Dairy Supply Chains
\end_layout

\begin_layout Author
Richard Ariong
\begin_inset Foot
status collapsed

\begin_layout Plain Layout
