\begin_layout Subsection
Design
\end_layout

\begin_layout Standard
\begin_inset CommandInset label
LatexCommand label
name "subsec:design"

\end_inset

[Placeholder describing the 2x2 factorial experimental design.
 Treatment 1 (Lactoscan): Cluster-randomized provision of a Lactoscan milk
 analyzer to MCCs.
 Treatment 2 (Video): Farmer-level randomization of a quality awareness
 video within all MCCs.
 The design allows estimation of the individual and joint effects of supply-side
 information (video) and demand-side measurement capacity (analyzer).]
\end_layout

