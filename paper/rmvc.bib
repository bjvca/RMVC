@article{RENNER2004575,
title = {Price rigidity in customer markets},
journal = {Journal of Economic Behavior & Organization},
volume = {55},
number = {4},
pages = {575-593},
year = {2004},
note = {Trust and Trustworthiness},
issn = {0167-2681},
doi = {https://doi.org/10.1016/j.jebo.2003.11.009},
url = {https://www.sciencedirect.com/science/article/pii/S0167268104000733},
author = {Elke Renner and Jean-Robert Tyran},
keywords = {Customer market, Price stickiness, Customer loyalty},
abstract = {Customer markets are characterized by long-term relationships between buyers and sellers that evolve if buyers trust sellers to provide high quality and if sellers are trustworthy. However, changes in the terms of this implicit contract may antagonize customers and disrupt the relationship. We experimentally show that mutually beneficial long-term relationships frequently prevail in markets for experience goods and that price rigidity after a temporary cost shock is much more pronounced if price increases cannot be justified by cost increases. Hence, long-term relationships in customer markets mitigate market failure of the “lemons” type, but are prone to price stickiness.}
}

